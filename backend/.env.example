# Exemplo de arquivo .env
# Copie para .env e ajuste os valores conforme necessário

# ============ DATABASE ============
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=iot_monitor
DB_POOL_SIZE=5
DB_POOL_NAME=iot_pool

# ============ MQTT ============
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=devices/#
MQTT_USERNAME=
MQTT_PASSWORD=

# ============ FLASK ============
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-in-production

# ============ LOGGING ============
LOG_LEVEL=INFO

# ============ API ============
API_LIMIT_READINGS=10000
API_TIMEOUT=30
